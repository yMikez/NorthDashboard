generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Platform {
  id          String    @id @default(cuid())
  slug        String    @unique
  displayName String
  isActive    Boolean   @default(true)
  lastSyncAt  DateTime?
  createdAt   DateTime  @default(now())

  // Taxa média de transação cobrada pela plataforma sobre cada venda
  // (ex: Digistore24 ~8.37%). Usuário atualiza manualmente — não é
  // derivada do payload do IPN (que muda por país/método). Multiplica
  // pelo faturado no período pra mostrar "Taxas pagas" no card.
  feeRatePct      Decimal? @db.Decimal(5, 2)
  // Percentual do faturamento que a plataforma retém como allowance
  // (rolling reserve contra refund/chargeback — Digistore ~2.37%).
  // Mesma lógica: usuário atualiza, multiplica pelo período.
  allowancePct    Decimal? @db.Decimal(5, 2)
  // Timestamp da última atualização dos % acima. Driva o popup de 7d
  // que solicita re-confirmação periódica dos valores.
  feesUpdatedAt   DateTime?

  orders     Order[]
  products   Product[]
  affiliates Affiliate[]
  customers  Customer[]
}

enum ProductType {
  FRONTEND
  UPSELL
  DOWNSELL
  BUMP
  SMS_RECOVERY
}

model Product {
  id             String      @id @default(cuid())
  platformId     String
  externalId     String
  name           String
  productType    ProductType
  funnelPosition Int?

  // Catalog metadata seeded from Planilhas/Products - *.csv. Authoritative
  // classification used by the dashboard's filters/grouping. The same SKU can
  // appear under multiple vendor accounts; vendorAccount disambiguates pricing
  // (catalogPriceUsd) but the unique key stays (platformId, externalId).
  family          String?
  variant         String?
  bottles         Int?
  // RC SKUs ship combo offers like "6 + 2 Bottles" where 2 are bonus. We
  // pay COGS + fulfillment for the total (bottles + bonusBottles).
  bonusBottles    Int?
  vendorAccount   String?
  catalogPriceUsd Decimal? @db.Decimal(10, 2)
  niche           String?
  salesPageUrl    String?
  checkoutUrl     String?
  thanksPageUrl   String?
  driveUrl        String?
  catalogStatus   String?

  parentProductId String?
  costOfGoods     Decimal? @db.Decimal(10, 2)
  currency        String   @default("USD")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  // Override de fornecedor de fulfillment por SKU. Quando NULL, herda do
  // ProductFamilyCost.fulfillmentSupplier da família. Permite ex.: marcar
  // SKUs individuais de FlexGuard como RedRock sem mexer no default da
  // família. Valores: 'redrock' | 'shipoffers'.
  fulfillmentSupplier String?

  platform Platform  @relation(fields: [platformId], references: [id])
  parent   Product?  @relation("FunnelTree", fields: [parentProductId], references: [id])
  children Product[] @relation("FunnelTree")
  orders   Order[]

  @@unique([platformId, externalId])
  @@index([family])
  @@index([family, productType])
}

model Affiliate {
  id          String    @id @default(cuid())
  platformId  String
  externalId  String
  nickname    String?
  firstSeenAt DateTime
  lastOrderAt DateTime?

  platform    Platform            @relation(fields: [platformId], references: [id])
  orders      Order[]
  // Network attachment is 1:1 — an affiliate belongs to at most one
  // network so commission attribution is unambiguous on each FE sale.
  networkLink NetworkAffiliate?
  commissions NetworkCommission[]

  @@unique([platformId, externalId])
  @@index([lastOrderAt])
}

model Customer {
  id          String    @id @default(cuid())
  platformId  String
  externalId  String
  email       String?
  firstName   String?
  lastName    String?
  language    String?
  country     String?
  firstSeenAt DateTime
  lastOrderAt DateTime?

  platform Platform @relation(fields: [platformId], references: [id])
  orders   Order[]

  @@unique([platformId, externalId])
  @@index([email])
}

enum OrderStatus {
  PENDING
  APPROVED
  REFUNDED
  CHARGEBACK
  CANCELED
}

enum BillingType {
  SINGLE_PAYMENT
  INSTALLMENT
  SUBSCRIPTION
  UNKNOWN
}

model Order {
  id                    String  @id @default(cuid())
  platformId            String
  externalId            String
  parentExternalId      String?
  previousTransactionId String?
  vendorAccount         String?
  productId             String
  affiliateId           String?
  customerId            String?

  currencyOriginal String
  grossAmountOrig  Decimal  @db.Decimal(12, 2)
  grossAmountUsd   Decimal  @db.Decimal(12, 2)
  // Snapshot do gross na PRIMEIRA vez que vimos esta order (na criação).
  // grossAmountUsd é overwritten pra negativo quando vem refund/chargeback;
  // originalGrossUsd preserva o valor da venda original pra reconciliação
  // estilo "Date of Event" (CB-style) e cálculo de "Receita bruta do dia"
  // que inclui vendas que depois foram refundadas.
  // Nullable só pra suportar migration; ingest novos sempre populam.
  originalGrossUsd Decimal? @db.Decimal(12, 2)
  taxAmount        Decimal  @default(0) @db.Decimal(12, 2)
  fees             Decimal  @default(0) @db.Decimal(12, 2)
  netAmountUsd     Decimal  @db.Decimal(12, 2)
  cpaPaidUsd       Decimal  @default(0) @db.Decimal(12, 2)

  // Per-order productType. Authoritative classification for THIS sale's role
  // in the funnel. The same SKU can be FE in one order and UPSELL in another
  // (e.g., NeuroMindPro-6-FE-vs2 sold direct vs as upgrade after 3-FE), so we
  // store role per-order, not per-product. Product.productType remains as a
  // catalog hint (most-recent observed type).
  productType ProductType @default(FRONTEND)

  status               OrderStatus
  eventType            String
  billingType          BillingType @default(UNKNOWN)
  paySequenceNo        Int?
  numberOfInstallments Int?

  paymentMethod String?
  country       String?
  state         String?
  city          String?

  funnelSessionId String?
  funnelStep      Int?
  clickId         String?
  trackingId      String?
  campaignKey     String?
  trafficSource   String?
  deviceType      String?
  browser         String?

  detailsUrl String?

  orderedAt    DateTime
  approvedAt   DateTime?
  refundedAt   DateTime?
  chargebackAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  rawMetadata Json?

  // Cost-of-goods snapshot at ingest time. Stored to preserve historical
  // accuracy: if pricing changes later, old orders still show the cost
  // they actually had. Computed via lib/services/cogs.ts.
  cogsUsd        Decimal? @db.Decimal(10, 2)
  fulfillmentUsd Decimal? @db.Decimal(10, 2)

  platform          Platform           @relation(fields: [platformId], references: [id])
  product           Product            @relation(fields: [productId], references: [id])
  affiliate         Affiliate?         @relation(fields: [affiliateId], references: [id])
  customer          Customer?          @relation(fields: [customerId], references: [id])
  // 1:1 — uma order FE de afiliado vinculado gera no máx 1 comissão de network.
  networkCommission NetworkCommission?

  @@unique([platformId, externalId])
  @@index([orderedAt])
  @@index([affiliateId, orderedAt])
  @@index([productId, orderedAt])
  @@index([status])
  @@index([funnelSessionId])
  @@index([parentExternalId])
  @@index([vendorAccount, orderedAt])
}

model FxRate {
  id    String   @id @default(cuid())
  date  DateTime @db.Date
  base  String
  quote String
  rate  Decimal  @db.Decimal(12, 6)

  @@unique([date, base, quote])
}

model IngestLog {
  id           String    @id @default(cuid())
  source       String
  platformSlug String
  eventType    String
  externalId   String?
  payload      Json
  signatureOk  Boolean?
  processedOk  Boolean   @default(false)
  error        String?
  receivedAt   DateTime  @default(now())
  processedAt  DateTime?

  @@index([platformSlug, receivedAt])
  @@index([processedOk])
  @@index([externalId])
}

// Per-family cost-of-goods. Editable via /api/admin/costs (and eventually a
// UI). Snapshot is captured into Order.cogsUsd at ingest time, so changing
// values here only affects future orders — historical numbers are preserved.
model ProductFamilyCost {
  family      String   @id // 'NeuroMindPro', 'GlycoPulse', etc.
  unitCostUsd Decimal  @db.Decimal(10, 4) // custo do pote NO FORNECEDOR desta família
  // Quem entrega esta família: 'redrock' | 'shipoffers'. Define qual
  // tabela de FulfillmentRate consultar e qual custo unitário aplicar.
  // NeuroMind + funil (NightCalm, FlexImmuneGuard) = redrock; resto = shipoffers.
  fulfillmentSupplier String @default("shipoffers")
  updatedAt   DateTime @updatedAt
}

// Fulfillment (shipping) por (fornecedor, família, bottlesMax). Lookup:
// "primeiro row do supplier+family cujo bottlesMax >= total, ordenado ASC".
// Se não houver row family-specific, cai pro family='_default' do supplier.
// priceUsd = custo de envio COMPLETO (ship+fee+pick+packaging+paper/fuel),
// SEM o custo do pote (esse vive em ProductFamilyCost.unitCostUsd).
model FulfillmentRate {
  supplier   String // 'redrock' | 'shipoffers'
  family     String // família ou '_default' (fallback do supplier)
  bottlesMax Int // maior contagem de potes coberta (1..6, 999 = 7+)
  priceUsd   Decimal  @db.Decimal(10, 2)
  label      String
  updatedAt  DateTime @updatedAt

  @@id([supplier, family, bottlesMax])
  @@index([supplier, family, bottlesMax])
}

enum UserRole {
  ADMIN
  MEMBER
  // Partner externo (network owner). Vê só os dados da própria network
  // — afiliados vinculados, comissões, payouts, contrato. Sem acesso ao
  // dashboard global.
  NETWORK_PARTNER
}

// Dashboard users. ADMIN sees everything and can manage other users.
// MEMBER sees only the tabs listed in allowedTabs (validated against
// AVAILABLE_TABS in lib/auth/tabs.ts at write time, not at the DB level).
// NETWORK_PARTNER is scoped to a single Network via networkId.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         UserRole  @default(MEMBER)
  allowedTabs  String[]  @default([])
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  createdById  String?
  // Pra role=NETWORK_PARTNER esse campo é obrigatório (FK pro Network
  // que ele representa). Pra ADMIN/MEMBER fica null.
  networkId    String?
  sessions     Session[]

  network         Network?          @relation(fields: [networkId], references: [id])
  signedContracts NetworkContract[] @relation("ContractSignedBy")
  paidPayouts     NetworkPayout[]   @relation("PayoutPaidBy")
  auditEntries    NetworkAuditLog[] @relation("AuditActor")
  conversations   Conversation[]    @relation("ConversationsByUser")
}

model Session {
  id        String   @id // random hex token; IS the cookie value
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@index([expiresAt])
}

// ============================================================
// NETWORKS — sub-affiliate program. Network = parceiro externo
// que indica afiliados pra promover nossos produtos. Cada venda
// FE aprovada de um afiliado vinculado gera comissão pro Network.
// Comissão é fixed (USD/venda) ou percent (% do gross). Payouts
// agregam comissões por período (a cada N dias/semanas/meses).
// Refunds NÃO afetam comissão já contabilizada (decisão de produto).
// ============================================================

enum NetworkStatus {
  ACTIVE
  PAUSED
}

enum CommissionType {
  FIXED // USD por venda FE
  PERCENT // fração do gross (0.05 = 5%)
}

enum PaymentPeriodUnit {
  DAYS
  WEEKS
  MONTHS
}

enum CommissionStatus {
  ACCRUED // contabilizada, aguardando virar payout
  PAID // já incluída num payout que foi marcado como pago
}

enum PayoutStatus {
  PENDING // gerado pelo sistema, aguardando admin marcar como pago
  PAID // admin confirmou que pagou
}

enum AuditEntityType {
  NETWORK
  NETWORK_PAYOUT
  NETWORK_AFFILIATE
  NETWORK_CONTRACT
}

model Network {
  id     String        @id @default(cuid())
  name   String
  slug   String        @unique
  status NetworkStatus @default(ACTIVE)

  // Comissão por venda FE de afiliado vinculado.
  // FIXED:   commissionValue = USD a pagar (ex: 25.00 = $25/FE)
  // PERCENT: commissionValue = fração (ex: 0.05 = 5% do gross)
  commissionType  CommissionType
  commissionValue Decimal        @db.Decimal(10, 4)

  // Periodicidade do payout. Próximo pagamento estimado =
  // último payout + (paymentPeriodValue * paymentPeriodUnit) ou
  // contractStart + período se nunca pagou.
  paymentPeriodValue Int
  paymentPeriodUnit  PaymentPeriodUnit @default(DAYS)

  contractStart DateTime @default(now())
  billingEmail  String?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  affiliates   NetworkAffiliate[]
  commissions  NetworkCommission[]
  payouts      NetworkPayout[]
  contracts    NetworkContract[]
  partnerUsers User[]

  @@index([status])
}

model NetworkAffiliate {
  id               String   @id @default(cuid())
  networkId        String
  affiliateId      String   @unique // 1:1 — afiliado pertence a no máx 1 network
  attachedAt       DateTime @default(now())
  attachedByUserId String?

  network   Network   @relation(fields: [networkId], references: [id], onDelete: Cascade)
  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@unique([networkId, affiliateId])
  @@index([networkId])
}

model NetworkCommission {
  id          String @id @default(cuid())
  networkId   String
  orderId     String @unique // 1:1 com FE order
  affiliateId String

  amountUsd Decimal          @db.Decimal(12, 4)
  status    CommissionStatus @default(ACCRUED)

  // Snapshot do tipo+valor da comissão NO MOMENTO da venda. Se admin
  // alterar a config da network depois, comissões antigas mantêm o
  // valor pactuado original.
  commissionType  CommissionType
  commissionValue Decimal        @db.Decimal(10, 4)

  payoutId  String?
  paidAt    DateTime?
  createdAt DateTime  @default(now())

  network   Network        @relation(fields: [networkId], references: [id], onDelete: Cascade)
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  affiliate Affiliate      @relation(fields: [affiliateId], references: [id])
  payout    NetworkPayout? @relation(fields: [payoutId], references: [id])

  @@index([networkId, status])
  @@index([networkId, createdAt])
  @@index([payoutId])
}

model NetworkPayout {
  id        String @id @default(cuid())
  networkId String

  totalUsd         Decimal @db.Decimal(12, 4)
  commissionsCount Int

  // Janela coberta pelo payout (do último payout até a geração).
  periodStart DateTime
  periodEnd   DateTime

  status        PayoutStatus @default(PENDING)
  paidAt        DateTime?
  paidByUserId  String?
  paymentMethod String? // ex: "wise", "pix", "bank-transfer" — texto livre
  notes         String?

  createdAt DateTime @default(now())

  network     Network             @relation(fields: [networkId], references: [id], onDelete: Cascade)
  paidBy      User?               @relation("PayoutPaidBy", fields: [paidByUserId], references: [id])
  commissions NetworkCommission[]

  @@index([networkId, periodEnd])
  @@index([status])
}

model NetworkContract {
  id        String @id @default(cuid())
  networkId String
  version   Int // bump a cada alteração nos termos da network

  // Markdown source com placeholders já substituídos pelos valores
  // específicos desta network/versão (snapshot imutável).
  contentMd String
  // Path relativo dentro de /public/uploads/contracts/. Servimos o PDF
  // via endpoint autenticado, não como static asset.
  pdfPath   String

  signedAt       DateTime?
  signedByUserId String?
  signatureIp    String?

  createdAt DateTime @default(now())

  network  Network @relation(fields: [networkId], references: [id], onDelete: Cascade)
  signedBy User?   @relation("ContractSignedBy", fields: [signedByUserId], references: [id])

  @@unique([networkId, version])
  @@index([networkId])
}

// ============================================================
// AI ASSISTANT — chat conversations + messages.
// Tool-use pattern: assistant chama services existentes via tools
// (get_overview, get_funnel, etc), respostas streamadas via SSE.
// Admin-only. Histórico persistido pra revisita.
// ============================================================

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("ConversationsByUser", fields: [userId], references: [id], onDelete: Cascade)
  title     String? // auto-gerado do primeiro user message (truncado)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@index([userId, updatedAt])
}

// Cada turno do chat. role='user' ou 'assistant'. toolUses guarda
// metadata pra renderizar no UI ([{name, input, result}]). content
// armazena a resposta final em texto markdown.
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // 'user' | 'assistant'
  content        String
  toolUses       Json?
  // Structured response blocks emitted by the `respond_with_blocks` tool.
  // Null pra mensagens em texto puro (markdown via `content`). Array de
  // Block discriminated union em types/chat.ts.
  blocks         Json?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// Base de conhecimento injetada no system prompt do chat AI. Cada entry
// vira um bloco markdown adicionado ao prompt quando `enabled=true`.
// Mantemos a tabela pequena (~10-30 entries esperados) pra não estourar
// o token budget — não tem retrieval, é tudo embedded.
model KnowledgeEntry {
  id        String   @id @default(cuid())
  title     String // "Regras de payout Digistore", "Glossário CB", etc.
  content   String // markdown — vai literal pro system prompt
  enabled   Boolean  @default(true)
  // 'manual' = criada pelo admin no painel. 'auto' = extraída pela IA
  // de conversas do chat (memória persistente cross-chat).
  source    String   @default("manual")
  // Ordem de exibição/injeção no prompt. Menor = primeiro.
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, sortOrder])
  @@index([source, createdAt])
}

// Audit trail genérico pra mudanças sensíveis em entidades de Network.
// Action é texto livre ("create", "update", "mark_paid",
// "attach_affiliate", "detach_affiliate", "regenerate_contract", ...).
model NetworkAuditLog {
  id          String          @id @default(cuid())
  actorUserId String
  entityType  AuditEntityType
  entityId    String
  action      String

  beforeJson Json?
  afterJson  Json?

  createdAt DateTime @default(now())

  actor User @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════════
// Copy Optimizer — exposição da copy "Black 2" no Upsell01 (BuyGoods)
// ═══════════════════════════════════════════════════════════════════

// Regra de exposição: quanto % dos leads de um afiliado vê a copy Black 2.
// Lida pelo /api/copy-decision a cada decisão pedida pelo funnel-renderer.
// Editada pelo painel /copy-optimizer (manual) ou pelo cron auto-tune.
model AffiliateCopyRule {
  id        String   @id @default(cuid())

  // aff_id (ex: "46") OU aff_name (ex: "Matheus Petersen"). Case-sensitive —
  // bate verbatim contra o que vem do INS BuyGoods (Affiliate.externalId/nickname).
  key       String   @unique
  // 'id' | 'name' — pra UI saber como exibir/filtrar.
  keyType   String

  // 0..100. % de leads desse afiliado que vê Black 2 (bucket sticky por venda).
  black2Pct Int      @default(0)

  // Se false, regra é ignorada (vira 0%).
  enabled   Boolean  @default(true)
  // Se true, o cron auto-tune ajusta o black2Pct (dentro de min/max/step).
  autotune  Boolean  @default(false)

  // Rails de segurança do auto-tune.
  minPct    Int      @default(0)
  maxPct    Int      @default(80)
  stepPct   Int      @default(5)

  // Target AOV específico do afiliado (opcional; senão usa o global da config).
  targetAov Decimal? @db.Decimal(10, 2)

  // Quem mudou por último: 'manual' | 'autotune' | 'seed'.
  updatedBy String   @default("manual")

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  logs AutotuneLog[]

  @@index([enabled, autotune])
}

// Cada visualização de copy registrada pelo funnel-renderer via /api/copy-view.
// Source-of-truth de "quem viu o quê e quando". Append-only.
model CopyView {
  id BigInt @id @default(autoincrement())

  // Bate com Order.parentExternalId (BuyGoods order_id_global).
  orderIdGlobal String

  // 'white' | 'black1' | 'black2' | 'loading'.
  layer String

  affId   String?
  affName String?

  // 0..99 — auditoria do bucket djb2 que decidiu.
  bucket Int?

  pageUrl  String?
  referrer String?
  sessid2  String?

  shownAt DateTime @default(now())

  @@index([orderIdGlobal])
  @@index([affName, shownAt])
  @@index([affId, shownAt])
  @@index([layer, shownAt])
}

// Log de cada decisão do auto-tune. Auditável e imutável.
model AutotuneLog {
  id BigInt @id @default(autoincrement())

  ruleId String
  rule   AffiliateCopyRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  pctBefore Int
  pctAfter  Int

  // 'aov_gap_up' | 'adverse_lift_down' | 'cap_hit' | 'cooldown' | 'no_sample' | 'hold'
  reason String

  // Snapshot das métricas no momento: { lift, n_b1, n_b2, aov_obs, aov_target, conv_b1, conv_b2 }
  metrics Json

  decidedAt DateTime @default(now())

  @@index([ruleId, decidedAt])
}
