generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Platform {
  id          String   @id @default(cuid())
  slug        String   @unique
  displayName String
  isActive    Boolean  @default(true)
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())

  orders     Order[]
  products   Product[]
  affiliates Affiliate[]
  customers  Customer[]
}

enum ProductType {
  FRONTEND
  UPSELL
  DOWNSELL
  BUMP
  SMS_RECOVERY
}

model Product {
  id              String      @id @default(cuid())
  platformId      String
  externalId      String
  name            String
  productType     ProductType
  funnelPosition  Int?

  // Catalog metadata seeded from Planilhas/Products - *.csv. Authoritative
  // classification used by the dashboard's filters/grouping. The same SKU can
  // appear under multiple vendor accounts; vendorAccount disambiguates pricing
  // (catalogPriceUsd) but the unique key stays (platformId, externalId).
  family          String?
  variant         String?
  bottles         Int?
  // RC SKUs ship combo offers like "6 + 2 Bottles" where 2 are bonus. We
  // pay COGS + fulfillment for the total (bottles + bonusBottles).
  bonusBottles    Int?
  vendorAccount   String?
  catalogPriceUsd Decimal?    @db.Decimal(10, 2)
  niche           String?
  salesPageUrl    String?
  checkoutUrl     String?
  thanksPageUrl   String?
  driveUrl        String?
  catalogStatus   String?

  parentProductId String?
  costOfGoods     Decimal?    @db.Decimal(10, 2)
  currency        String      @default("USD")
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())

  platform Platform  @relation(fields: [platformId], references: [id])
  parent   Product?  @relation("FunnelTree", fields: [parentProductId], references: [id])
  children Product[] @relation("FunnelTree")
  orders   Order[]

  @@unique([platformId, externalId])
  @@index([family])
  @@index([family, productType])
}

model Affiliate {
  id          String    @id @default(cuid())
  platformId  String
  externalId  String
  nickname    String?
  firstSeenAt DateTime
  lastOrderAt DateTime?

  platform Platform @relation(fields: [platformId], references: [id])
  orders   Order[]

  @@unique([platformId, externalId])
  @@index([lastOrderAt])
}

model Customer {
  id          String    @id @default(cuid())
  platformId  String
  externalId  String
  email       String?
  firstName   String?
  lastName    String?
  language    String?
  country     String?
  firstSeenAt DateTime
  lastOrderAt DateTime?

  platform Platform @relation(fields: [platformId], references: [id])
  orders   Order[]

  @@unique([platformId, externalId])
  @@index([email])
}

enum OrderStatus {
  PENDING
  APPROVED
  REFUNDED
  CHARGEBACK
  CANCELED
}

enum BillingType {
  SINGLE_PAYMENT
  INSTALLMENT
  SUBSCRIPTION
  UNKNOWN
}

model Order {
  id                    String      @id @default(cuid())
  platformId            String
  externalId            String
  parentExternalId      String?
  previousTransactionId String?
  vendorAccount         String?
  productId             String
  affiliateId           String?
  customerId            String?

  currencyOriginal String
  grossAmountOrig  Decimal @db.Decimal(12, 2)
  grossAmountUsd   Decimal @db.Decimal(12, 2)
  taxAmount        Decimal @db.Decimal(12, 2) @default(0)
  fees             Decimal @db.Decimal(12, 2) @default(0)
  netAmountUsd     Decimal @db.Decimal(12, 2)
  cpaPaidUsd       Decimal @db.Decimal(12, 2) @default(0)

  // Per-order productType. Authoritative classification for THIS sale's role
  // in the funnel. The same SKU can be FE in one order and UPSELL in another
  // (e.g., NeuroMindPro-6-FE-vs2 sold direct vs as upgrade after 3-FE), so we
  // store role per-order, not per-product. Product.productType remains as a
  // catalog hint (most-recent observed type).
  productType ProductType @default(FRONTEND)

  status      OrderStatus
  eventType   String
  billingType BillingType @default(UNKNOWN)
  paySequenceNo      Int?
  numberOfInstallments Int?

  paymentMethod String?
  country       String?
  state         String?
  city          String?

  funnelSessionId String?
  funnelStep      Int?
  clickId         String?
  trackingId      String?
  campaignKey     String?
  trafficSource   String?
  deviceType      String?
  browser         String?

  detailsUrl String?

  orderedAt    DateTime
  approvedAt   DateTime?
  refundedAt   DateTime?
  chargebackAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  rawMetadata Json?

  // Cost-of-goods snapshot at ingest time. Stored to preserve historical
  // accuracy: if pricing changes later, old orders still show the cost
  // they actually had. Computed via lib/services/cogs.ts.
  cogsUsd        Decimal? @db.Decimal(10, 2)
  fulfillmentUsd Decimal? @db.Decimal(10, 2)

  platform  Platform   @relation(fields: [platformId], references: [id])
  product   Product    @relation(fields: [productId], references: [id])
  affiliate Affiliate? @relation(fields: [affiliateId], references: [id])
  customer  Customer?  @relation(fields: [customerId], references: [id])

  @@unique([platformId, externalId])
  @@index([orderedAt])
  @@index([affiliateId, orderedAt])
  @@index([productId, orderedAt])
  @@index([status])
  @@index([funnelSessionId])
  @@index([parentExternalId])
  @@index([vendorAccount, orderedAt])
}

model FxRate {
  id    String   @id @default(cuid())
  date  DateTime @db.Date
  base  String
  quote String
  rate  Decimal  @db.Decimal(12, 6)

  @@unique([date, base, quote])
}

model IngestLog {
  id           String    @id @default(cuid())
  source       String
  platformSlug String
  eventType    String
  externalId   String?
  payload      Json
  signatureOk  Boolean?
  processedOk  Boolean   @default(false)
  error        String?
  receivedAt   DateTime  @default(now())
  processedAt  DateTime?

  @@index([platformSlug, receivedAt])
  @@index([processedOk])
  @@index([externalId])
}

// Per-family cost-of-goods. Editable via /api/admin/costs (and eventually a
// UI). Snapshot is captured into Order.cogsUsd at ingest time, so changing
// values here only affects future orders — historical numbers are preserved.
model ProductFamilyCost {
  family       String   @id  // 'NeuroMindPro', 'GlycoPulse', etc.
  unitCostUsd  Decimal  @db.Decimal(10, 4)
  updatedAt    DateTime @updatedAt
}

// Fulfillment (shipping) brackets. Lookup is "first row whose maxBottles
// >= order.totalBottles, ordered by maxBottles ASC". Weight isn't tracked
// — the supplier prices already account for our specific bottle weights,
// so we map bottle count directly to bracket.
model FulfillmentRate {
  bottlesMax  Int      @id        // largest bottle count covered (e.g. 2, 3, 4, ...)
  priceUsd    Decimal  @db.Decimal(10, 2)
  label       String              // human display ("0 to 2.99 oz", etc.)
  updatedAt   DateTime @updatedAt
}

enum UserRole {
  ADMIN
  MEMBER
}

// Dashboard users. ADMIN sees everything and can manage other users.
// MEMBER sees only the tabs listed in allowedTabs (validated against
// AVAILABLE_TABS in lib/auth/tabs.ts at write time, not at the DB level).
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          UserRole  @default(MEMBER)
  allowedTabs   String[]  @default([])
  active        Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  createdById   String?
  sessions      Session[]
}

model Session {
  id         String   @id   // random hex token; IS the cookie value
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  ipAddress  String?
  userAgent  String?

  @@index([userId])
  @@index([expiresAt])
}
