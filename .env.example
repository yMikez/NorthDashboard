# Database
DATABASE_URL="postgresql://dashboard:dashboard@localhost:5432/dashboard"

# Ingest auth — compartilhado com o N8N, adicionado como header X-Ingest-Secret
INGEST_SECRET="11446c1b5b1fbfdee7bf4fe72824ad8a"

# Digistore24 — SHA passphrase configurada no painel como "IPN password" (nomenclatura confusa, mas é isso)
DIGISTORE24_IPN_PASSPHRASE="NorthScaleReports"

# ClickBank API (Fase 2 — polling/reconciliação)
# Mesma chave pra read e write (a chave carrega os dois roles)
# Formato: API-<valor gerado no painel ClickBank>
CLICKBANK_API_KEY_READ="API-F16DHP10HL26X2YXWJJ8QEA5M92CVF6J2OPQ"
CLICKBANK_API_KEY_WRITE="API-F16DHP10HL26X2YXWJJ8QEA5M92CVF6J2OPQ"
# Contas vendor às quais esta chave tem acesso (comma-separated nicknames)
# Ex: neurompro,burnthermo,maxvitaliz,glycopulse
CLICKBANK_VENDORS="neurompro,burnthermo,maxvitaliz,glycopulse"

# Job auth (Fase 2)
JOB_SECRET="JobSecretQueServePraAlgoQueNaoSei"

# ============================================================
# Email (SMTP) — usado pra avisar partners de eventos:
#   - Network criada (welcome + credenciais + termos)
#   - Payout marcado como pago (confirmação)
#   - Termos do contrato alterados (re-aceite necessário)
#
# Fail-soft: se SMTP_PASS estiver vazio ou SMTP der erro, a operação
# continua normalmente (admin não é bloqueado). Email vira no-op com log.
#
# Pra Hostinger: SMTP_PASS é a senha que você definiu na hPanel quando
# criou a caixa de email. Reseta pelo painel se esquecer.
# ============================================================
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false                       # true só pra port 465 (SSL puro)
SMTP_USER=dashboard@northcloacker.com
SMTP_PASS=                              # ⚠ NÃO commitar valor real — preencher só no .env do servidor
SMTP_FROM_EMAIL=dashboard@northcloacker.com
SMTP_FROM_NAME=NorthScale

# Base URL pública do dashboard, usada nos links dos emails.
DASHBOARD_URL=https://dash.thenorthscales.com
